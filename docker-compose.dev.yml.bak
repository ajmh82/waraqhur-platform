services:
  app-dev:
    image: node:22-bookworm-slim
    container_name: waraqhur-app-dev
    working_dir: /app
    restart: unless-stopped
    depends_on:
      - db
    env_file:
      - .env.production
    environment:
      NODE_ENV: "development"
      CHOKIDAR_USEPOLLING: "true"
      WATCHPACK_POLLING: "true"
    command: >
      sh -c "apt-get update -y &&
      apt-get install -y openssl &&
      rm -rf /var/lib/apt/lists/* &&
      if [ ! -d node_modules/@prisma/client ]; then npm ci; fi &&
      npx prisma generate &&
      npm run dev -- --hostname 0.0.0.0 --port 3000"
    ports:
      - "3002:3000"
      - "3003:3000"
    volumes:
      - .:/app
      - waraqhur_dev_node_modules:/app/node_modules

  db:
    image: postgres:16-alpine
    container_name: waraqhur-db
    restart: unless-stopped
    environment:
      POSTGRES_DB: waraqhur
      POSTGRES_USER: waraqhur
      POSTGRES_PASSWORD: waraqhur_password
    volumes:
      - waraqhur_postgres_data:/var/lib/postgresql/data

volumes:
  waraqhur_postgres_data:
  waraqhur_dev_node_modules:
